{
  "name": "photon-engine",
  "version": "0.1.0",
  "description": "Lightweight 2D game engine with ECS architecture",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["game-engine", "2d", "ecs", "webgl", "typescript", "electron", "photon"],
  "author": "bssm-oss",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bssm-oss/Ion.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/bssm-oss/Ion#readme",
  "bugs": {
    "url": "https://github.com/bssm-oss/Ion/issues"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
