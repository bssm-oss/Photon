{
  "name": "photon-engine-browser",
  "version": "0.1.0",
  "description": "Browser adapter for Photon Engine (OPFS filesystem, Web API bridge)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
