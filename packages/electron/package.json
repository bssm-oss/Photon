{
  "name": "@ion-engine/electron",
  "version": "0.1.0",
  "description": "Electron adapter for Ion Engine",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "electron": "^28.0.0",
    "ion-engine": "^0.1.0"
  },
  "devDependencies": {
    "ion-engine": "file:../core",
    "typescript": "^5.6.0"
  },
  "license": "MIT"
}
